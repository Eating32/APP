/**
 * Y-Evolution 主页面 — change_1.txt 严格规格
 */

/* ========================================
   页面容器
   ======================================== */
.page-container {
  padding: 0 20rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ========================================
   1. Header
   ======================================== */
/* 手机状态栏 — 固定在页面最顶部 */
.phone-status-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; flex-direction: row; justify-content: space-between;
  align-items: center;
  padding: 6rpx 24rpx;
  padding-top: calc(6rpx + env(safe-area-inset-top));
  background: rgba(244, 248, 255, 0.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}
.phone-time {
  font-size: 26rpx; font-weight: 600; color: #1F3C75;
  font-family: "Microsoft YaHei", sans-serif;
}
.phone-battery-wrap {
  display: flex; flex-direction: row; align-items: center; gap: 8rpx;
}
.battery-icon {
  width: 44rpx; height: 22rpx; border-radius: 6rpx;
  border: 2rpx solid #1F3C75; padding: 2rpx;
  display: flex; align-items: center;
}
.battery-fill {
  height: 100%; border-radius: 3rpx;
  background: #25C06D;
  transition: width 0.3s ease;
}
.battery-percent {
  font-size: 22rpx; font-weight: 600; color: #1F3C75;
  font-family: "Microsoft YaHei", sans-serif;
}

.header {
  display: flex; flex-direction: row; justify-content: space-between;
  align-items: flex-start; padding: 0 8rpx; padding-top: 4rpx;
}
.header-left { display: flex; flex-direction: column; }
.header-title {
  font-size: 72rpx; font-weight: 700; color: #234A95;
  line-height: 1; letter-spacing: -1rpx;
  font-family: "Microsoft YaHei", sans-serif;
}
.header-subtitle {
  font-size: 24rpx; color: #7F90AF; margin-top: 8rpx;
  font-family: "Microsoft YaHei", sans-serif;
}

/* 蓝牙连接按钮 */
.ble-btn {
  display: flex; flex-direction: row; align-items: center; gap: 8rpx;
  padding: 10rpx 20rpx; border-radius: 999rpx;
  background: rgba(61, 123, 255, 0.08);
  border: 1px solid rgba(61, 123, 255, 0.2);
  margin-top: 8rpx;
}
.ble-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #8293B5;
}
.ble-label {
  font-size: 22rpx; font-weight: 600; color: #8293B5;
  font-family: "Microsoft YaHei", sans-serif;
}
.ble-scanning .ble-dot {
  background: #F59E0B;
  animation: ble-blink 0.8s ease-in-out infinite;
}
.ble-scanning .ble-label { color: #F59E0B; }
.ble-connected .ble-dot { background: #25C06D; }
.ble-connected .ble-label { color: #25C06D; }
@keyframes ble-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* ========================================
   2. 设备卡片（高度 260rpx，由组件控制）
   ======================================== */
.device-card-wrapper { overflow: visible; margin-top: 4rpx; }

/* ========================================
   3. 当前状态卡片（~120rpx）
   ======================================== */
.status-card {
  width: 100%;
  display: flex; 
  flex-direction: row; 
  align-items: center; 
  justify-content: space-between;
  padding: 24rpx 28rpx;
  height: 120rpx;
  transform: translateY(-22rpx);
}
.status-label {
  font-size: 28rpx; font-weight: 700; color: #1F3C75;
  font-family: "Microsoft YaHei", sans-serif;
}
.status-pill { padding: 8rpx 24rpx; border-radius: 40rpx; }
.status-pill-text { font-size: 26rpx; font-weight: 700; font-family: "Microsoft YaHei", sans-serif; }
.status-desc {
  font-size: 26rpx; color: #8293B5; font-weight: 500;
  font-family: "Microsoft YaHei", sans-serif;
}
.status-pill-idle { background: #E9F9EF; }
.status-pill-idle .status-pill-text { color: #25C06D; }
.status-pill-moving { background: #EAF2FF; }
.status-pill-moving .status-pill-text { color: #3D7BFF; }
.status-pill-collecting { background: #F3EFFF; }
.status-pill-collecting .status-pill-text { color: #7C3AED; }
.status-pill-serving { background: #FFF4E6; }
.status-pill-serving .status-pill-text { color: #F59E0B; }
.status-pill-shutdown { background: #F1F3F5; }
.status-pill-shutdown .status-pill-text { color: #8293B5; }

/* ========================================
   4. 主功能区：左右双栏 58% : 42%
   ======================================== */
.main-area { 
  display: flex; 
  flex-direction: row; 
  gap: 18rpx; 
  position: relative;
  top: -8rpx; }

/* --- 左列 58%：移动控制 ~420rpx --- */
.left-column {
  width: 58%;
  display: flex; flex-direction: column;
  padding: 16rpx 20rpx;
  flex: 1;
}
.right-column {
  width: 42%;
  display: flex; 
  flex-direction: column; 
  gap: 20rpx;
  
}
.right-column > .glass-card { flex: 1; }

.column-header { display: flex; flex-direction: column; margin-bottom: 6rpx; }
.column-title {
  font-size: 28rpx; font-weight: 700; color: #1F3C75; margin-bottom: 2rpx;
  font-family: "Microsoft YaHei", sans-serif;
}
.column-subtitle {
  font-size: 22rpx; color: #8293B5; font-weight: 500;
  font-family: "Microsoft YaHei", sans-serif;
}
.segment-wrap { margin-bottom: 6rpx; }

/* 摇杆区域 */
.joystick-area {
  flex: 1;
  display: flex; justify-content: center; align-items: center;
  padding: 8rpx 0;
}

/* --- 收球功能 --- */
.func-section-collect {
  display: flex; flex-direction: column;
  padding: 28rpx;
}
.func-section-collect .column-header { margin-bottom: 14rpx; }

/* --- 发球功能 --- */
.func-section-serve {
  display: flex; flex-direction: column;
  padding: 28rpx;
}
.func-section-serve .column-header { margin-bottom: 6rpx; }
.func-section-serve .segment-wrap { margin-bottom: 8rpx; }

/* 统一主按钮 */
.func-btn, .func-btn-serve {
  width: 100%;
  height: 72rpx;
  margin-top: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4A8CFF, #2F66FF);
  box-shadow:
    0 6rpx 18rpx rgba(47, 102, 255, 0.25),
    0 0 0 1rpx rgba(255, 255, 255, 0.3) inset;
  display: flex; justify-content: center; align-items: center;
}
.func-btn text, .func-btn-serve text {
  font-size: 32rpx; font-weight: 600; color: #fff;
  font-family: "Microsoft YaHei", sans-serif;
}
.btn-active-state {
  background: linear-gradient(135deg, #25C06D, #1EA85A) !important;
  box-shadow: 0 6rpx 18rpx rgba(37, 192, 109, 0.25),
              0 0 0 1rpx rgba(255, 255, 255, 0.3) inset !important;
}
.btn-primary-press { transform: scale(0.97); }

/* 档位 */
.speed-row { display: flex; flex-direction: row; gap: 10rpx; margin: 30rpx 0; }
.speed-btn {
  flex: 1; height: 58rpx; border-radius: 999rpx;
  background: #EDF1F6;
  display: flex; justify-content: center; align-items: center;
}
.speed-btn-text {
  font-size: 26rpx; font-weight: 600; color: #8293B5;
  font-family: "Microsoft YaHei", sans-serif;
}
.speed-active {
  background: linear-gradient(135deg, #4A8CFF, #2F66FF);
  box-shadow: 0 4rpx 12rpx rgba(47,102,255,0.2);
}
.speed-active .speed-btn-text { color: #fff; font-weight: 700; }

/* ========================================
   5. 总关闭模块
   ======================================== */
.shutdown-card {
  width: 100%;
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between; padding: 20rpx 28rpx;
  margin-top: 15rpx
}
.shutdown-info { flex: 1; display: flex; flex-direction: column; min-width: 0; }
.shutdown-title {
  font-size: 28rpx; font-weight: 700; color: #1F3C75; margin-bottom: 4rpx;
  font-family: "Microsoft YaHei", sans-serif;
}
.shutdown-subtitle {
  font-size: 22rpx; color: #8293B5; font-weight: 500;
  font-family: "Microsoft YaHei", sans-serif;
}
.shutdown-switch { flex-shrink: 0; margin-left: 16rpx; }

/* ========================================
   紧凑底部
   ======================================== */
.bottom-spacer { height: 30rpx; }

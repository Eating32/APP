/**
 * 蓝牙连接页面 · Apple 风格
 */
.page-container {
  padding: 0 20rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  min-height: 100vh;
  box-sizing: border-box;
}

/* ---- 导航栏 ---- */
.ble-nav {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between;
  height: 80rpx; margin-bottom: 20rpx; padding: 0 8rpx;
}
.nav-back { display: flex; flex-direction: row; align-items: center; gap: 6rpx; }
.nav-back-icon { font-size: 32rpx; color: #3D7BFF; font-weight: 700; }
.nav-back-text { font-size: 28rpx; color: #3D7BFF; font-weight: 600; }
.nav-title {
  font-size: 32rpx; font-weight: 700; color: #1F3C75;
  font-family: "Microsoft YaHei", sans-serif;
}
.nav-placeholder { width: 100rpx; }

/* ---- 蓝牙开关卡片 ---- */
.ble-switch-card {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx; margin-bottom: 16rpx;
}
.switch-left { display: flex; flex-direction: column; }
.switch-title {
  font-size: 28rpx; font-weight: 700; color: #1F3C75; margin-bottom: 4rpx;
  font-family: "Microsoft YaHei", sans-serif;
}
.switch-subtitle {
  font-size: 22rpx; color: #8293B5; font-weight: 500;
  font-family: "Microsoft YaHei", sans-serif;
}

/* ---- 已连接设备卡片 ---- */
.connected-card { padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.connected-header { display: flex; flex-direction: row; align-items: center; gap: 8rpx; margin-bottom: 20rpx; }
.connected-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #25C06D; }
.connected-label {
  font-size: 26rpx; font-weight: 700; color: #25C06D;
  font-family: "Microsoft YaHei", sans-serif;
}
.connected-info { display: flex; flex-direction: column; gap: 14rpx; margin-bottom: 24rpx; }
.connected-row { display: flex; flex-direction: row; justify-content: space-between; align-items: center; }
.connected-key { font-size: 24rpx; color: #8293B5; font-weight: 500; }
.connected-val {
  font-size: 24rpx; font-weight: 700; color: #1F3C75;
  font-family: "Microsoft YaHei", sans-serif; max-width: 300rpx; text-align: right;
}
.connected-id { font-size: 18rpx; opacity: 0.6; }
.connected-actions { display: flex; flex-direction: row; gap: 16rpx; }
.action-btn {
  flex: 1; height: 64rpx; border-radius: 999rpx;
  display: flex; justify-content: center; align-items: center;
  font-size: 26rpx; font-weight: 600;
  font-family: "Microsoft YaHei", sans-serif;
}
.action-disconnect { background: #EAF2FF; color: #3D7BFF; }
.action-forget { background: #F1F3F5; color: #8293B5; }

/* ---- 连接中 ---- */
.connecting-card { padding: 40rpx 28rpx; margin-bottom: 16rpx; }
.connecting-wrap { display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 16rpx; }
.connecting-spinner {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  border: 3rpx solid #E6ECF7; border-top-color: #3D7BFF;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.connecting-text {
  font-size: 28rpx; font-weight: 600; color: #3D7BFF;
  font-family: "Microsoft YaHei", sans-serif;
}

/* ---- 扫描区域 ---- */
.scan-section { margin-bottom: 16rpx; }

.scan-card { padding: 20rpx 28rpx; margin-bottom: 16rpx; }
.scan-btn {
  width: 100%; height: 72rpx; border-radius: 999rpx;
  background: linear-gradient(135deg, #4A8CFF, #2F66FF);
  display: flex; justify-content: center; align-items: center;
  box-shadow: 0 6rpx 18rpx rgba(47, 102, 255, 0.25);
}
.scan-btn.scanning {
  background: #EDF1F6;
  box-shadow: none;
}
.scan-btn-text {
  font-size: 28rpx; font-weight: 600; color: #fff;
  font-family: "Microsoft YaHei", sans-serif;
}
.scan-btn.scanning .scan-btn-text { color: #8293B5; }

/* ---- 设备列表 ---- */
.list-title {
  font-size: 24rpx; font-weight: 700; color: #8293B5;
  margin-bottom: 12rpx; padding-left: 8rpx;
  font-family: "Microsoft YaHei", sans-serif;
}
.device-list { display: flex; flex-direction: column; gap: 12rpx; }

.device-item {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
}
.device-item.item-connecting { opacity: 0.6; }

.device-info { flex: 1; min-width: 0; }
.device-name {
  font-size: 28rpx; font-weight: 700; color: #1F3C75; margin-bottom: 8rpx;
  font-family: "Microsoft YaHei", sans-serif;
  display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.device-rssi { display: flex; flex-direction: row; align-items: center; gap: 8rpx; }
.rssi-bars { display: flex; flex-direction: row; align-items: flex-end; gap: 3rpx; }
.rssi-bar { width: 6rpx; height: 14rpx; border-radius: 2rpx; background: #E8ECF4; }
.rssi-bar.active { background: #25C06D; }
.rssi-bar:nth-child(2) { height: 20rpx; }
.rssi-bar:nth-child(3) { height: 26rpx; }
.rssi-bar:nth-child(4) { height: 32rpx; }
.rssi-text { font-size: 20rpx; color: #8293B5; font-weight: 500; }

.device-connect-btn {
  padding: 12rpx 28rpx; border-radius: 999rpx;
  background: #EAF2FF; flex-shrink: 0; margin-left: 16rpx;
}
.device-connect-btn text { font-size: 24rpx; font-weight: 600; color: #3D7BFF; }
.device-connect-btn.connecting { background: #F1F3F5; }
.device-connect-btn.connecting text { color: #8293B5; }

/* ---- 空状态 ---- */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 0;
}
.empty-title {
  font-size: 28rpx; font-weight: 700; color: #1F3C75; margin-bottom: 8rpx;
  font-family: "Microsoft YaHei", sans-serif;
}
.empty-desc { font-size: 22rpx; color: #8293B5; font-weight: 500; }

/* ---- 底部留白 ---- */
.bottom-spacer { height: 60rpx; }

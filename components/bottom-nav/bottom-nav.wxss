/**
 * 磨砂玻璃底部导航栏
 * iOS Dock 风格
 */

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
  border-radius: 40rpx 40rpx 0 0;
  overflow: hidden;
}

/* 顶部玻璃高光 */
.nav-highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.8);
  z-index: 3;
}

/* 磨砂玻璃背景层 */
.nav-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 -8rpx 30rpx rgba(30, 60, 120, 0.06);
}

/* 导航内容 */
.nav-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  height: 110rpx;
  padding: 0 20rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 20rpx;
  gap: 4rpx;
}

.nav-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #A0AEC8;
  font-family: "Microsoft YaHei", sans-serif;
  transition: color 0.2s ease;
}

.nav-active .nav-label {
  color: #3D7BFF;
}

/* ========================================
   CSS 图标 — 44rpx
   ======================================== */
.nav-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* --- 控制：靶心图标 --- */
.icon-circle {
  width: 32rpx; height: 32rpx; border-radius: 50%;
  border: 4rpx solid #A0AEC8;
  display: flex; justify-content: center; align-items: center;
  transition: border-color 0.2s ease;
}
.icon-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: #A0AEC8; transition: background 0.2s ease;
}
.nav-active .icon-circle { border-color: #3D7BFF; }
.nav-active .icon-dot { background: #3D7BFF; }

/* --- 状态：三条柱状图 --- */
.icon-bars {
  display: flex; flex-direction: row; align-items: flex-end;
  gap: 5rpx; height: 32rpx;
}
.icon-bar { width: 7rpx; border-radius: 3rpx; background: #A0AEC8; }
.bar-1 { height: 18rpx; } .bar-2 { height: 26rpx; } .bar-3 { height: 32rpx; }
.nav-active .icon-bar { background: #3D7BFF; }

/* --- 设置：齿轮图标 --- */
.icon-gear {
  width: 30rpx; height: 30rpx; border-radius: 50%;
  border: 4rpx solid #A0AEC8;
  display: flex; justify-content: center; align-items: center;
  transition: border-color 0.2s ease;
}
.icon-gear-inner {
  width: 10rpx; height: 10rpx; border-radius: 50%;
  background: #A0AEC8; transition: background 0.2s ease;
}
.nav-active .icon-gear { border-color: #3D7BFF; }
.nav-active .icon-gear-inner { background: #3D7BFF; }

/* --- 我的：人物图标 --- */
.icon-person {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
}
.icon-head {
  width: 18rpx; height: 18rpx; border-radius: 50%;
  border: 4rpx solid #A0AEC8; transition: border-color 0.2s ease;
}
.icon-body {
  width: 28rpx; height: 14rpx; border-radius: 14rpx 14rpx 0 0;
  border: 4rpx solid #A0AEC8; border-bottom: none;
  transition: border-color 0.2s ease;
}
.nav-active .icon-head, .nav-active .icon-body { border-color: #3D7BFF; }

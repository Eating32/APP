<!-- 设备信息卡片 — 动态连接状态 -->
<view class="device-card glass-card">
  <!-- 左侧：机器人图片 -->
  <view class="device-image-wrap">
    <image class="device-image"
           src="/images/robot.png" mode="aspectFit"
           bindload="onImageLoad" binderror="onImageError" />
    <view class="image-placeholder" wx:if="{{!imageLoaded}}">
      <text class="placeholder-text">ELF</text>
    </view>
  </view>

  <!-- 右侧：设备信息白色卡片 -->
  <view class="device-info">
    <view class="device-info-card {{connected ? '' : 'card-disconnected'}}">
      <text class="device-name {{connected ? '' : 'disconnected'}}">{{deviceName}}</text>
      <text class="device-model">{{deviceModel}}</text>

      <!-- 电量 / 已用时长 — 仅连接时显示 -->
      <view class="info-row" wx:if="{{connected}}">
        <view class="info-item">
          <view class="battery-ring">
            <view class="ring-track">
              <view class="ring-fill" style="background: conic-gradient(#25C06D {{battery * 3.6}}deg, #E8ECF4 {{battery * 3.6}}deg);"></view>
              <view class="ring-center">
                <text class="ring-value">{{battery}}%</text>
              </view>
            </view>
          </view>
          <text class="info-label">电量</text>
        </view>

        <view class="info-item">
          <text class="info-value">{{usageTime}}</text>
          <text class="info-label">已用时长</text>
        </view>
      </view>
    </view>
  </view>
</view>
